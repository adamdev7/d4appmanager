# App
DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

# Database (SQLite default; use PostgreSQL in production)
DATABASE_URL=sqlite:///./data/app_manager.db

# Security — generate with: py -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-random-hex
# Optional dedicated Fernet key (else derived from JWT secret in dev)
ENCRYPTION_KEY=

# Email verification (SMTP) — required for real signup emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true

# Shopify Partner app — https://partners.shopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,read_customers,read_fulfillments,write_orders

# Google Cloud OAuth — Gmail API enabled
# Redirect URI: {APP_URL}/api/v1/gmail/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI — optional dev fallback if users have not saved their own key in the app
# Each user stores their key encrypted in the database via AI Email Assistant settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Order tracking page (optional carrier enrichment)
TRACK17_API_KEY=
YUNEXPRESS_API_KEY=
YUNEXPRESS_API_URL=https://api.yunexpress.com
